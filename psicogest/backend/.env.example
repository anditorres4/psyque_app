SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_JWK={"kty":"EC","crv":"P-256","alg":"ES256","x":"...","y":"...","kid":"..."}
SUPABASE_DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres

# App
APP_URL=http://localhost:5173
ENVIRONMENT=development

# Email (Resend, optional)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@psyque.app

# Google Calendar OAuth2 (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/google-calendar/callback
